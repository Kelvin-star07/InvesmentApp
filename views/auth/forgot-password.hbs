<div class="mt-5">
<div class="row mt-5 d-flex justify-content-center">
  <div class="col-12 col-sm-6 col-md-4 col-lg-4">
     <div class="card">
        <div class="card-header bg-secondary text-white">
            <h3 class="text-center fw-bold">Forgot password</h3>
        </div>
        <div class="card-body bg-light fw-bold">
           <form action="/forgot-password" method="POST">
             <div class="mb-3">
               <label for="email" class="form-label">Email address</label>
               <input type="email" class="form-control" id="email" name="Email">
             </div>
             
             <div class="mb-3">
               <button type="submit" class="btn btn-outline-primary float-end">Save</button>
               <a href="/" class="btn btn-outline-info float-end me-2">Back to login</a>
             </div>
           </form>
        </div>
     </div> 
  </div>
</div>
</div>
