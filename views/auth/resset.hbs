
<div class="mt-5">
<div class="row mt-5 d-flex justify-content-center">
  <div class="col-12 col-sm-6 col-md-4 col-lg-4">
     <div class="card">
        <div class="card-header bg-secondary text-white">
            <h3 class="text-center fw-bold">Reset Password</h3>
        </div>
        <div class="card-body bg-light fw-bold">
           <form action="/reset-password" method="POST">
               
               <input type="hidden" name="passwordToken" value="{{passwordToken}}"/>
               <input type="hidden" name="userId" value="{{userId}}"/>
                
             <div class="mb-3">
               <label for="password" class="form-label">Password</label>
               <input type="password" class="form-control" id="password" name="Password">
             </div>

             <div class="mb-3">
               <label for="confirm-password" class="form-label">Confirm Password</label>
               <input type="password" class="form-control" id="confirm-password" name="ConfirmPassword">
             </div>
             <div class="mb-3">
               <button type="submit" class="btn btn-outline-primary float-end"> <i class="bi bi-floppy"></i>  Save</button>
               <a href="/" class="btn btn-outline-warning float-end me-2">Back to login</a>
             </div>
           </form>
        </div>
     </div> 
  </div>
</div>
</div>
