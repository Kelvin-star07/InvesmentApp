
<div class="mt-5">
<div class="row mt-5 d-flex justify-content-center">
  <div class="col-12 col-sm-6 col-md-4 col-lg-4">
     <div class="card">
        <div class="card-header bg-primary text-white">
            <h3 class="text-center fw-bold">Register</h3>
        </div>
        <div class="card-body bg-light fw-bold">
           <form action="/user-register" method="POST">
           <div class="mb-3">
               <label for="name" class="form-label">Name</label>
               <input type="text" class="form-control" id="name" name="Name">
            </div>
             <div class="mb-3">
               <label for="email" class="form-label">Email address</label>
               <input type="email" class="form-control" id="email" name="Email">
             </div>

             <div class="mb-3">
               <label for="password" class="form-label">Password</label>
               <input type="password" class="form-control" id="password" name="Password">
             </div>
           
 
           <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword">
             </div>

             <div class="mb-3">
               <button type="submit" class="btn btn-outline-primary float-end">Register</button>
               <a href="/" class="btn btn-outline-secondary float-end me-3">Back to login</a>
             </div>
           </form>
        </div>
     </div> 
  </div>
</div>
</div>
